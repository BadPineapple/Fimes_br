-- 1. Tabelas sem Chaves Estrangeiras (Base)
CREATE TABLE TBLROL (
    id INT PRIMARY KEY AUTO_INCREMENT,
    nome_role VARCHAR(50) NOT NULL
);

CREATE TABLE TBLGEN (
    id INT PRIMARY KEY AUTO_INCREMENT,
    genero VARCHAR(50) NOT NULL
);

CREATE TABLE TBLPES (
    id INT PRIMARY KEY AUTO_INCREMENT,
    pessoa VARCHAR(100) NOT NULL
);

CREATE TABLE TBLTAG (
    id INT PRIMARY KEY AUTO_INCREMENT,
    tag VARCHAR(50) NOT NULL
);

CREATE TABLE TLBPLA (
    id INT PRIMARY KEY AUTO_INCREMENT,
    plataforma VARCHAR(100) NOT NULL,
    link VARCHAR(255)
);

-- 2. Tabela de Login (Usuários)

CREATE TABLE TBLLOGIN (
    id INT PRIMARY KEY AUTO_INCREMENT,
    usuario VARCHAR(50) UNIQUE NOT NULL,
    email VARCHAR(100) UNIQUE NOT NULL,
    senha VARCHAR(255) NOT NULL,
    telefone VARCHAR(20),
    data DATE,
    ultimo_acesso DATETIME
);

CREATE TABLE TBLUSER (
    id INT PRIMARY KEY AUTO_INCREMENT,
    login_id INT UNIQUE NOT NULL,
    nome VARCHAR(100) NOT NULL,
    descricao TEXT,
    data_nascimento DATE,
    apoiador BOOLEAN DEFAULT FALSE,
    propaganda BOOLEAN DEFAULT FALSE,
    FOREIGN KEY (login_id) REFERENCES login(id) ON DELETE CASCADE
);

-- 3. Tabela de Filmes
-- Nota: Para campos como 'elenco', o ideal seria uma tabela N:N, 
-- mas seguindo seu diagrama, eles estão como FKs diretas.
CREATE TABLE TBLFIL (
    id INT PRIMARY KEY AUTO_INCREMENT,
    titulo VARCHAR(150) NOT NULL,
    diretor INT,
    elenco INT,
    roterista INT,
    plataforma INT,
    genero INT,
    sinopse TEXT,
    tags INT,
    imagens VARCHAR(255),
    duracao VARCHAR(20),
    ano INT,
    FOREIGN KEY (diretor) REFERENCES pessoas(id) ON DELETE RESTRICT,
    FOREIGN KEY (elenco) REFERENCES pessoas(id) ON DELETE RESTRICT,
    FOREIGN KEY (roterista) REFERENCES pessoas(id) ON DELETE RESTRICT,
    FOREIGN KEY (plataforma) REFERENCES Plataformas(id) ON DELETE RESTRICT,
    FOREIGN KEY (genero) REFERENCES generos(id) ON DELETE RESTRICT,
    FOREIGN KEY (tags) REFERENCES tags(id) ON DELETE RESTRICT
);

-- 4. Tabelas de Relacionamento e Dependência


CREATE TABLE TBLLOGROL (
    id INT PRIMARY KEY AUTO_INCREMENT,
    role INT,
    usuario INT,
    FOREIGN KEY (role) REFERENCES Roles(id) ON DELETE RESTRICT ,
    FOREIGN KEY (login) REFERENCES Login(id) ON DELETE CASCADE 
);

CREATE TABLE TBLREV (
    id INT PRIMARY KEY AUTO_INCREMENT,
    usuario INT,
    nota INT CHECK (nota >= 0 AND nota <= 10),
    comentario TEXT,
    data DATE,
    filme INT,
    status VARCHAR(20),
    FOREIGN KEY (usuario) REFERENCES Login(id) ON DELETE CASCADE,
    FOREIGN KEY (filme) REFERENCES Filmes(id) ON DELETE CASCADE
);