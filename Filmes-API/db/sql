-- 1. Tabelas sem Chaves Estrangeiras (Base)
CREATE TABLE Roles (
    id INT PRIMARY KEY AUTO_INCREMENT,
    nome_role VARCHAR(50) NOT NULL -- Ajustado de 'genero' para 'nome_role'
);

CREATE TABLE generos (
    id INT PRIMARY KEY AUTO_INCREMENT,
    genero VARCHAR(50) NOT NULL
);

CREATE TABLE pessoas (
    id INT PRIMARY KEY AUTO_INCREMENT,
    pessoa VARCHAR(100) NOT NULL
);

CREATE TABLE tags (
    id INT PRIMARY KEY AUTO_INCREMENT,
    tag VARCHAR(50) NOT NULL
);

CREATE TABLE Plataformas (
    id INT PRIMARY KEY AUTO_INCREMENT,
    plataforma VARCHAR(100) NOT NULL,
    link VARCHAR(255)
);

-- 2. Tabela de Login (Usuários)
CREATE TABLE usuarios (
    id INT PRIMARY KEY AUTO_INCREMENT,
    usuario VARCHAR(50) UNIQUE NOT NULL,
    email VARCHAR(100) UNIQUE NOT NULL,
    senha VARCHAR(255) NOT NULL,
    telefone VARCHAR(20),
    data DATE,
    ultimo_acesso DATETIME
);

-- 3. Tabela de Filmes
-- Nota: Para campos como 'elenco', o ideal seria uma tabela N:N, 
-- mas seguindo seu diagrama, eles estão como FKs diretas.
CREATE TABLE Filmes (
    id INT PRIMARY KEY AUTO_INCREMENT,
    titulo VARCHAR(150) NOT NULL,
    diretor INT,
    elenco INT,
    roterista INT,
    plataforma INT,
    genero INT,
    sinopse TEXT,
    tags INT,
    imagens VARCHAR(255),
    duracao VARCHAR(20),
    ano INT,
    FOREIGN KEY (diretor) REFERENCES pessoas(id),
    FOREIGN KEY (elenco) REFERENCES pessoas(id),
    FOREIGN KEY (roterista) REFERENCES pessoas(id),
    FOREIGN KEY (plataforma) REFERENCES Plataformas(id),
    FOREIGN KEY (genero) REFERENCES generos(id),
    FOREIGN KEY (tags) REFERENCES tags(id)
);

-- 4. Tabelas de Relacionamento e Dependência
CREATE TABLE usuarios_roles (
    id INT PRIMARY KEY AUTO_INCREMENT,
    role INT,
    usuario INT,
    FOREIGN KEY (role) REFERENCES Roles(id),
    FOREIGN KEY (usuario) REFERENCES Login(id)
);

CREATE TABLE Reviews (
    id INT PRIMARY KEY AUTO_INCREMENT,
    usuario INT,
    nota INT CHECK (nota >= 0 AND nota <= 10),
    comentario TEXT,
    data DATE,
    filme INT,
    status VARCHAR(20),
    FOREIGN KEY (usuario) REFERENCES Login(id),
    FOREIGN KEY (filme) REFERENCES Filmes(id)
);